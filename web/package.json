{
  "name": "@laisky/accounting-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:dead": "NODE_OPTIONS=--experimental-require-module knip",
    "gen:api": "openapi-typescript ../docs/api/openapi.yaml -o src/lib/api/generated/schema.d.ts && prettier --write src/lib/api/generated/schema.d.ts",
    "check:api": "openapi-typescript ../docs/api/openapi.yaml -o src/lib/api/generated/schema.d.ts && prettier --write src/lib/api/generated/schema.d.ts && git diff --exit-code -- src/lib/api/generated/schema.d.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:i18n": "node scripts/check-i18n-locales.mjs",
    "test": "NODE_OPTIONS=--experimental-require-module vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^6.0.3",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-router": "^8.1.0",
    "vite": "^8.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@oxc-parser/binding-linux-x64-gnu": "0.137.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.24.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
